      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.12583ac114s6gj1ge802z1gaqkpz].[pcto:usr:Calculation_0494526961999872:qk]&quot;' value='% of Total YTD Sales' />
        </aliases>
      </column>
      <column datatype='string' name='[Body Style]' role='dimension' type='nominal' />
      <column caption='YTD Total Sales' datatype='integer' default-format='c&quot;$&quot;#,##0,,.00M;&quot;$&quot;-#,##0,,.00M' name='[Calculation_0494526961999872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF YEAR([Date]) = {MAX(YEAR([Date]))}&#13;&#10;THEN [Price ($)]&#13;&#10;END)' />
      </column>
      <column caption='YoY Sales Growth' datatype='real' default-format='p0.00%' name='[Calculation_0494527001874434]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0494526961999872]-[YTD Total Sales (copy)_0494527001075713])/[YTD Total Sales (copy)_0494527001075713]' />
      </column>
      <column caption='YTD Cars Sold' datatype='integer' default-format='c&quot;#&quot;#,##0,.00K;(&quot;#&quot;#,##0,.00K)' name='[Calculation_0494527006191619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Date])= {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='YoY Cars Sold Growth' datatype='real' default-format='p0.00%' name='[Calculation_0494527006941189]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0494527006191619] - [YTD Cars Sold (copy)_0494527006736388])/[YTD Cars Sold (copy)_0494527006736388]' />
      </column>
      <column caption='YTD Avg Price' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;&quot;$&quot;-#,##0,.00K' name='[Calculation_0494527010459654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0494526961999872] / [Calculation_0494527006191619]' />
      </column>
      <column caption='PYTD Avg Price' datatype='real' name='[Calculation_0494527010729991]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD Total Sales (copy)_0494527001075713] / [YTD Cars Sold (copy)_0494527006736388]' />
      </column>
      <column caption='YoY Avg Growth' datatype='real' default-format='p0.00%' name='[Calculation_0494527010975752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0494527010459654] - [Calculation_0494527010729991]) / [Calculation_0494527010729991]' />
      </column>
      <column caption='Min Date' datatype='date' name='[Calculation_0494527123271693]' role='dimension' type='ordinal'>
